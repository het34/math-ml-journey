   "source": [
    "# @name: Vectors and Dot Products\n",
    "# @topic: Linear Algebra\n",
    "# @level: Beginner\n",
    "# @description: Understanding vector operations, magnitude, and the geometric intuition behind dot products using NumPy.\n",
    "# @tags: numpy, vectors, dot-product, linear-algebra"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "first-code",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "\n",
    "# Define two vectors\n",
    "a = np.array([2, 3, 1])\n",
    "b = np.array([1, 4, 2])\n",
    "\n",
    "# Dot product\n",
    "dot = np.dot(a, b)\n",
    "print(f'Dot product: {dot}')\n",
    "\n",
    "# Magnitude\n",
    "mag_a = np.linalg.norm(a)\n",
    "print(f'|a| = {mag_a:.4f}')"
   ]
  }
 ]
}
