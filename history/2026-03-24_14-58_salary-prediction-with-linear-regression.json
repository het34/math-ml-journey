{
  "name": "Salary Prediction with Linear Regression",
  "topic": "Linear Algebra",
  "level": "Beginner",
  "description": "Building a linear regression model from scratch using NumPy to predict salary based on experience and skills. Covers weights, bias, gradient descent, and visualization.",
  "tags": [
    "numpy",
    "matplotlib",
    "linear-regression",
    "gradient-descent",
